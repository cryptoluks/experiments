        "partitions": [
          {
            "name": "Kalender",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    StartDate = #date(2023, 1, 1),\n    EndDate = #date(2025, 12, 31),\n    DateList = List.Dates(StartDate, Duration.Days(EndDate - StartDate) + 1, #duration(1, 0, 0, 0)),\n    #\"Tabelle\" = Table.FromList(DateList, Splitter.SplitByNothing(), {\"Datum\"}, null, ExtraValues.Error),\n    #\"Typ\" = Table.TransformColumnTypes(#\"Tabelle\", {{\"Datum\", type date}}),\n    #\"Jahr\" = Table.AddColumn(#\"Typ\", \"Jahr\", each Date.Year([Datum]), Int64.Type),\n    #\"Monat\" = Table.AddColumn(#\"Jahr\", \"Monat\", each Date.Month([Datum]), Int64.Type),\n    #\"MonatName\" = Table.AddColumn(#\"Monat\", \"MonatName\", each Date.ToText([Datum], \"MMM\"), type text),\n    #\"Quartal\" = Table.AddColumn(#\"MonatName\", \"Quartal\", each \"Q\" & Text.From(Date.QuarterOfYear([Datum])), type text),\n    #\"JahrMonat\" = Table.AddColumn(#\"Quartal\", \"JahrMonat\", each Date.ToText([Datum], \"yyyy-MM\"), type text)\nin\n    #\"JahrMonat\""
            }
          }
        ]
      }
    ],
