        ],
        "partitions": [
          {
            "name": "Anlagengitter",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let\n    Quelle = Csv.Document(File.Contents(\"data/sap_b1_anlagengitter.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.None]),\n    #\"Höher gestufte Header\" = Table.PromoteHeaders(Quelle, [PromoteAllScalars=true]),\n    #\"Geänderter Typ\" = Table.TransformColumnTypes(#\"Höher gestufte Header\", {\n        {\"ItemCode\", type text}, {\"ItemName\", type text}, {\"AssetClass\", Int64.Type},\n        {\"AssetClassName\", type text}, {\"CapDate\", type date},\n        {\"AHK_Vortrag\", type number}, {\"Zugang\", type number}, {\"Abgang\", type number},\n        {\"AHK_Endstand\", type number}, {\"AfA_Vortrag\", type number},\n        {\"AfA_Zugang\", type number}, {\"AfA_Abgang\", type number},\n        {\"AfA_Endstand\", type number}, {\"Buchwert_Anfang\", type number},\n        {\"Buchwert_Ende\", type number}, {\"Nutzungsdauer\", Int64.Type},\n        {\"AfA_Methode\", type text}, {\"Kostenstelle\", type text},\n        {\"Standort\", type text}, {\"Status\", type text}, {\"BuchungsMonat\", type text}\n    })\nin\n    #\"Geänderter Typ\""
            }
          }
        ],
        "measures": [
          {
            "name": "Anfangsbestand",
            "expression": "SUM(Anlagengitter[AHK_Vortrag])",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000001"
          },
          {
            "name": "Zugänge",
            "expression": "SUM(Anlagengitter[Zugang])",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000002"
          },
          {
            "name": "Abschreibungen",
            "expression": "SUM(Anlagengitter[AfA_Zugang])",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000003"
          },
          {
            "name": "Abgänge",
            "expression": "SUM(Anlagengitter[Abgang])",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000004"
          },
          {
            "name": "Restbuchwert",
            "expression": "SUM(Anlagengitter[Buchwert_Ende])",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000005"
          },
          {
            "name": "Anzahl Anlagen",
            "expression": "COUNTROWS(Anlagengitter)",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000006"
          },
          {
            "name": "Zugänge Vormonat",
            "expression": "VAR CurrentMonth = MAX(Anlagengitter[BuchungsMonat]) VAR PrevMonth = FORMAT(DATEADD(DATE(LEFT(CurrentMonth,4), MID(CurrentMonth,6,2), 1), -1, MONTH), \"YYYY-MM\") RETURN CALCULATE([Zugänge], Anlagengitter[BuchungsMonat] = PrevMonth)",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000007"
          },
          {
            "name": "Delta Vormonat Zugänge",
            "expression": "[Zugänge] - [Zugänge Vormonat]",
            "formatString": "#,##0",
            "lineageTag": "m001-0001-0001-0001-000000000008"
          },
          {
            "name": "Delta Vormonat Zugänge %",
            "expression": "DIVIDE([Delta Vormonat Zugänge], [Zugänge Vormonat], 0)",
            "formatString": "0.0%",
            "lineageTag": "m001-0001-0001-0001-000000000009"
          }
        ]
      },
      {
